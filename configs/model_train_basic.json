{
  "datapath": "ETHUSDT_6_1h.csv",

  "slicing": {
    "type": "candles",
    "candles": [3000, 1000],
    "from_tail": true,
    "end_date": null,
    "time_col": "open_time_eth"
  },

  "builder": {
    "horizon": 1,
    "tau_pct": [0.03, null],
    "features_include": null,
    "extra_drop": ["regime", "future_ret"],
    "future_ret_col": "future_ret",
    "regime_filter": ["trend_up"],
    "feature_groups": ["all"]
  },

  "model": {
    "task": "classification",
    "hidden": 64,
    "depth": 3,
    "dropout": 0.1,
    "lr": 0.001,
    "weight_decay": 0.0001,
    "batch_size": 128,
    "epochs": 40,
    "patience": 6,
    "val_share": 0.2,
    "seed": 42,
    "verbose": false
  }
}
